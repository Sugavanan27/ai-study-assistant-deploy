# Version Control Ignore File

# Virtual Environment
venv/
.venv/
ENV/
env/

# Databases & Vector Stores
chroma_db/
academic_assistant.db
*.db
*.sqlite

# Sensitive Configuration & Keys
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Dependency folders
node_modules/
frontend/node_modules/

# Next.js Build Output
frontend/.next/
frontend/out/

# Python Cache & Compiled Files
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# Uploaded Files
backend/uploads/*
!backend/uploads/.gitkeep

# System & IDE Files
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.log
